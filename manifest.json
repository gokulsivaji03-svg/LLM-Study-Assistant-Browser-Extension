{
  "manifest_version": 3,
  "name": "StudyAI",
  "version": "2.4",
  "description": "Automates Smartbook quiz workflows by routing questions to ChatGPT, Gemini, or DeepSeek and applying the returned answers in-page.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://learning.mheducation.com/*",
    "https://ezto.mheducation.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://deepseek.chat/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "48": "assets/icon.png"
  },
  "action": {
    "default_popup": "popup/settings.html",
    "default_icon": "assets/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://learning.mheducation.com/static/awd/*"],
      "js": ["content-scripts/mheducation.js"]
    },
    {
      "matches": ["https://ezto.mheducation.com/*"],
      "js": ["content-scripts/ezto-mheducation.js"]
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content-scripts/chatgpt.js"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-scripts/gemini.js"]
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content-scripts/deepseek.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup/settings.html",
        "popup/settings.css",
        "popup/settings.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
